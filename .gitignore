# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyd

# Distribution / Packaging
.Python
build/
dist/
eggs/
.eggs/
*.egg-info/
*.egg
MANIFEST
sdist/
wheels/
pip-wheel-metadata/
share/python-wheels/

# Virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# ── Jupyter Notebook ─────────────────────────────────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/
profile_default/
ipython_config.py

# ── NumPy / PyTorch / 모델 캐시 ───────────────────────────────────────────────
*.npy
*.npz
*.pkl
*.pickle
*.joblib
*.pt
*.pth
*.ckpt
*.safetensors
*.onnx

# Framework caches (PyTorch, HuggingFace)
.torch_cache/
.hf_cache/
.cache/huggingface/
transformers_cache/

# ── Sequence / Text Dataset 캐시 ──────────────────────────────────────────────
# 각 챕터의 실험에서 다운로드되는 corpus / processed 결과
# Ch1-02 N-gram LM (Brown, Gutenberg, PTB),
# Ch1-03 Bengio NLM (Penn Treebank),
# Ch2-03 Truncated BPTT (PTB perplexity),
# Ch3 Adding/Copy/Reverse synthetic memory tasks,
# Ch4 Adding Problem (T=200) forget bias ablation,
# Ch5-01 BiLSTM-CRF (CoNLL-2003 NER),
# Ch5-03 NTM (copy / repeat-copy / associative recall),
# Ch6 Seq2Seq (WMT'14 En-Fr / IWSLT / Multi30k),
# Ch7-04 Mamba / S4 (Long Range Arena, Path-X)
data/
datasets/
corpora/
ptb/
wikitext/
brown/
gutenberg/
imdb/
conll03/
multi30k/
iwslt/
wmt14/
wmt16/
lra/                           # Long Range Arena
path-x/
mackey-glass/
synthetic_tasks/
raw/
processed/
!data/.gitkeep

# Tokenizer / vocab
*.vocab
*.spm                          # SentencePiece model
*.bpe                          # Byte Pair Encoding
vocab.txt
sp.model
nltk_data/

# Downloaded text / parallel corpus
*.txt.gz
*.tsv.gz
*.tar.gz
*.zip

# ── Experiment outputs ───────────────────────────────────────────────────────
# 생성된 이미지·시각화 결과물 (각 챕터)
# Ch1: word embedding 시각화·perplexity vs N 비교,
# Ch2: BPTT gradient 시간축 plot·truncation k 별 perplexity,
# Ch3: Pascanu spectral radius 분포·gradient norm exponential decay,
# Ch4: LSTM gate activation·CEC gradient 보존·forget bias ablation,
# Ch5: NTM memory read/write head·ESN reservoir dynamics,
# Ch6: Bahdanau/Luong attention heatmap·BLEU vs sentence length,
# Ch7: Transformer vs LSTM 훈련 시간·Mamba LRA 결과
*.png
*.jpg
*.jpeg
*.svg
*.pdf
*.gif
*.mp4
*.webp

